 2: import '../models/provider_model.dart';
 3: class ProvidersRepository {
 4:   final FirebaseFirestore _firestore;
 5:   ProvidersRepository({
 6:     FirebaseFirestore? firestore,
 7:   }) : _firestore = firestore ?? FirebaseFirestore.instance;
 8:   // ── LEITURA PÚBLICA ───────────────────────────────────────────────────────────
 9:   Stream<List<ProviderModel>> watchProvidersByCategory({
10:     required String categoryId,
11:   }) {
12:     return _firestore
13:         .collection('providers')
14:         .where('isActive', isEqualTo: true)
15:         .where('categoryId', isEqualTo: categoryId)
16:         .snapshots()
17:         .map((snapshot) {
18:       final providers = snapshot.docs.map((doc) {
19:         return ProviderModel.fromMap(doc.data(), id: doc.id);
20:       }).toList();
21:       providers.sort((a, b) => a.name.compareTo(b.name));
22:       return providers;
23:     });
24:   }
25:   Stream<List<ProviderModel>> watchProvidersForSearch({
26:     required String searchQuery,
27:   }) {
28:     return _firestore
29:         .collection('providers')
30:         .where('isActive', isEqualTo: true)
31:         .snapshots()
32:         .map((snapshot) {
33:       final providers = snapshot.docs.map((doc) {
34:         return ProviderModel.fromMap(doc.data(), id: doc.id);
35:       }).toList();
36:       final normalizedQuery = searchQuery.trim().toLowerCase();
37:       if (normalizedQuery.isEmpty) {
38:         providers.sort((a, b) => a.name.compareTo(b.name));
39:         return providers;
40:       }
41:       final filtered = providers.where((provider) {
42:         return provider.name.toLowerCase().contains(normalizedQuery) ||
43:             provider.description.toLowerCase().contains(normalizedQuery) ||
44:             provider.categoryName.toLowerCase().contains(normalizedQuery);
45:       }).toList();
46:       filtered.sort((a, b) => a.name.compareTo(b.name));
47:       return filtered;
48:     });
49:   }
50:   // ── ADMIN ────────────────────────────────────────────────────────────────────
51:   /// Stream de sugestões aguardando aprovação.
52:   Stream<List<ProviderModel>> watchPendingProviders() {
53:     return _firestore
54:         .collection('providers')
55:         .where('status', isEqualTo: 'pending')
56:         .snapshots()
57:         .map((snapshot) {
58:       final providers = snapshot.docs.map((doc) {
59:         return ProviderModel.fromMap(doc.data(), id: doc.id);
60:       }).toList();
61:       providers.sort((a, b) => a.name.compareTo(b.name));
62:       return providers;
63:     });
64:   }
65:   /// Admin adiciona prestador diretamente (já ativo).
66:   Future<void> addProvider({required ProviderModel provider}) async {
67:     await _firestore.collection('providers').add(provider.toMap());
68:   }
69:   /// Aprovar sugestão: torna o prestador visível no app.
70:   Future<void> approveProvider(String id) async {
71:     await _firestore.collection('providers').doc(id).update({
72:       'isActive': true,
73:       'status': 'active',
74:     });
75:   }
76:   /// Rejeitar sugestão: oculta o prestador sem excluir.
77:   Future<void> rejectProvider(String id) async {
78:     await _firestore.collection('providers').doc(id).update({
79:       'status': 'rejected',
80:     });
81:   }
82:   // ── USUÁRIO ──────────────────────────────────────────────────────────────────
83:   /// Usuário sugere um prestador (fica pendente até admin aprovar).
84:   Future<void> suggestProvider({required ProviderModel provider}) async {
85:     await _firestore.collection('providers').add(provider.toMap());
