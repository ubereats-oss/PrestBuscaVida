 18: 
 19: function Copy-IfExists($relativePath) {
 20:   $src = Join-Path $projectRoot $relativePath
 21:   if (Test-Path $src) {
 22:     $dst = Join-Path $staging $relativePath
 23:     $dstDir = Split-Path $dst -Parent
 24:     if (!(Test-Path $dstDir)) { New-Item -ItemType Directory -Path $dstDir | Out-Null }
 25: 
 26:     if ((Get-Item $src).PSIsContainer) {
