<file path="lib/data/repositories/auth_repository.dart">
  1: import 'package:cloud_firestore/cloud_firestore.dart';
  2: import 'package:firebase_auth/firebase_auth.dart';
  3: import '../models/user_model.dart';
  4: import 'package:sign_in_with_apple/sign_in_with_apple.dart';
  5: 
  6: class AuthRepository {
  7:   final FirebaseAuth _auth;
  8:   final FirebaseFirestore _firestore;
  9:   AuthRepository({FirebaseAuth? auth, FirebaseFirestore? firestore})
 10:     : _auth = auth ?? FirebaseAuth.instance,
 11:       _firestore = firestore ?? FirebaseFirestore.instance;
 12:   Stream<User?> get authStateChanges => _auth.authStateChanges();
 13:   User? get currentUser => _auth.currentUser;
 14:   // ── E-MAIL ──────────────────────────────────────────────────────────────
 15:   Future<UserModel> signInWithEmail({
 16:     required String email,
 17:     required String password,
 18:   }) async {
 19:     final credential = await _auth.signInWithEmailAndPassword(
 20:       email: email,
 21:       password: password,
 22:     );
 23:     final userModel = await _getUserDocument(credential.user!.uid);
 24:     if (userModel == null) {
 25:       throw Exception('Usuário não encontrado. Crie uma conta primeiro.');
 26:     }
 27:     return userModel;
 28:   }
 29: 
 30:   Future<UserModel> registerWithEmail({
 31:     required String email,
 32:     required String password,
 33:     required String displayName,
 34:   }) async {
 35:     final credential = await _auth.createUserWithEmailAndPassword(
 36:       email: email,
 37:       password: password,
 38:     );
 39:     final user = credential.user!;
 40:     await user.updateDisplayName(displayName);
 41:     final role = await _claimAdminIfFirst(user.uid);
 42:     return _createUserDocument(user, role: role, displayName: displayName);
 43:   }
 44: 
 45:   // ── TELEFONE ──────────────────────────────────────────────────────────────
 46:   /// Passo 1: enviar SMS.
 47:   /// O número deve estar no formato E.164, ex: +5511999998888
 48:   Future<void> startPhoneVerification({
 49:     required String phoneNumber,
 50:     required String displayName,
 51:     required void Function(String verificationId) onCodeSent,
 52:     required void Function(String error) onError,
 53:     required void Function(UserModel user) onAutoVerified,
 54:   }) async {
 55:     await _auth.verifyPhoneNumber(
 56:       phoneNumber: phoneNumber,
 57:       verificationCompleted: (PhoneAuthCredential credential) async {
 58:         // Android: verificação automática sem digitar o código
 59:         final result = await _auth.signInWithCredential(credential);
 60:         final user = result.user!;
 61:         final existing = await _getUserDocument(user.uid);
 62:         if (existing != null) {
 63:           onAutoVerified(existing);
 64:           return;
 65:         }
 66:         final role = await _claimAdminIfFirst(user.uid);
 67:         final userModel = await _createUserDocument(
 68:           user,
 69:           role: role,
 70:           displayName: displayName,
 71:         );
 72:         onAutoVerified(userModel);
 73:       },
 74:       verificationFailed: (FirebaseAuthException e) {
 75:         onError(e.message ?? 'Erro ao verificar o telefone.');
 76:       },
 77:       codeSent: (String verificationId, int? resendToken) {
 78:         onCodeSent(verificationId);
 79:       },
 80:       codeAutoRetrievalTimeout: (_) {},
 81:     );
 82:   }
 83: 
 84:   /// Passo 2: validar o código SMS digitado pelo usuário.
 85:   Future<UserModel> signInWithPhoneCode({
 86:     required String verificationId,
 87:     required String smsCode,
 88:     required String displayName,
 89:   }) async {
 90:     final credential = PhoneAuthProvider.credential(
 91:       verificationId: verificationId,
 92:       smsCode: smsCode,
 93:     );
 94:     final result = await _auth.signInWithCredential(credential);
 95:     final user = result.user!;
 96:     // Usuário já tinha conta → apenas retorna o documento existente
 97:     final existing = await _getUserDocument(user.uid);
 98:     if (existing != null) return existing;
 99:     // Novo usuário
100:     final role = await _claimAdminIfFirst(user.uid);
101:     return _createUserDocument(user, role: role, displayName: displayName);
102:   }
103: 
104:   // ── GERAL ─────────────────────────────────────────────────────────────────
105:   Future<void> signOut() async {
106:     await _auth.signOut();
107:   }
108: 
109:   Future<UserModel?> getCurrentUserModel() async {
110:     final user = _auth.currentUser;
111:     if (user == null) return null;
112:     return _getUserDocument(user.uid);
113:   }
114: 
115:   // ── PRIVADOS ──────────────────────────────────────────────────────────────
116:   /// Usa um contador atômico em 'meta/stats' para garantir que somente o
117:   /// primeiro usuário a se cadastrar receba role 'admin', sem race condition.
118:   Future<String> _claimAdminIfFirst(String uid) async {
119:     final statsRef = _firestore.collection('meta').doc('stats');
120:     String role = 'user';
121:     await _firestore.runTransaction((transaction) async {
122:       final snap = await transaction.get(statsRef);
123:       final count = snap.exists ? (snap.data()!['userCount'] ?? 0) as int : 0;
124:       if (count == 0) {
125:         role = 'admin';
126:       }
127:       transaction.set(statsRef, {
128:         'userCount': count + 1,
129:       }, SetOptions(merge: true));
130:     });
131:     return role;
132:   }
133: 
134:   Future<UserModel> _createUserDocument(
135:     User firebaseUser, {
136:     required String role,
137:     required String displayName,
138:   }) async {
139:     final name = displayName.isNotEmpty
140:         ? displayName
141:         : (firebaseUser.displayName ?? firebaseUser.phoneNumber ?? 'Usuário');
142:     final userModel = UserModel(
143:       uid: firebaseUser.uid,
144:       email: firebaseUser.email,
145:       phone: firebaseUser.phoneNumber,
146:       displayName: name,
147:       role: role,
148:       createdAt: DateTime.now(),
149:     );
150:     await _firestore
151:         .collection('users')
152:         .doc(firebaseUser.uid)
153:         .set(userModel.toMap());
154:     return userModel;
155:   }
156: 
157:   Future<UserModel?> _getUserDocument(String uid) async {
158:     final doc = await _firestore.collection('users').doc(uid).get();
159:     if (!doc.exists || doc.data() == null) return null;
160:     return UserModel.fromMap(doc.data()!, uid: uid);
161:   }
162: }
163: 
164: Future<void> signInWithApple() async {
165:   final appleCredential = await SignInWithApple.getAppleIDCredential(
166:     scopes: [
167:       AppleIDAuthorizationScopes.email,
168:       AppleIDAuthorizationScopes.fullName,
169:     ],
170:   );
171: 
172:   final oauthCredential = OAuthProvider("apple.com").credential(
173:     idToken: appleCredential.identityToken,
174:     accessToken: appleCredential.authorizationCode,
175:   );
176: 
177:   await FirebaseAuth.instance.signInWithCredential(oauthCredential);
178: }
