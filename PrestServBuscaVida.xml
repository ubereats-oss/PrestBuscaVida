15: 
16: if (Test-Path $staging) { Remove-Item $staging -Recurse -Force }
17: New-Item -ItemType Directory -Path $staging | Out-Null
18: 
19: function Copy-IfExists($relativePath) {
20:   $src = Join-Path $projectRoot $relativePath
21:   if (Test-Path $src) {
22:     $dst = Join-Path $staging $relativePath
