 40: page_content = """\
 41: import 'package:flutter/material.dart';
 42: import 'package:flutter/services.dart';
 43: 
 44: import '../../data/models/category_model.dart';
 45: import '../../data/repositories/categories_repository.dart';
 46: import '../providers/providers_page.dart';
 47: 
 48: class CategoriesPage extends StatefulWidget {
 49:   const CategoriesPage({super.key});
 50: 
 51:   @override
 52:   State<CategoriesPage> createState() => _CategoriesPageState();
 53: }
 54: 
 55: class _CategoriesPageState extends State<CategoriesPage> {
 56:   final _repository = CategoriesRepository();
 57:   final _searchController = TextEditingController();
 58:   final _scrollController = ScrollController();
 59: 
 60:   late Future<List<CategoryModel>> _future;
 61:   List<CategoryModel> _all = [];
 62:   List<CategoryModel> _filtered = [];
 63:   String? _activeLetter;
 64:   List<String> _letters = [];
 65:   final Map<String, GlobalKey> _sectionKeys = {};
 66: 
 67:   @override
 68:   void initState() {
 69:     super.initState();
 70:     _future = _repository.fetchActiveCategories();
 71:     _future.then((list) {
 72:       _all = list;
 73:       _applyFilter('');
 74:     });
 75:   }
 76: 
 77:   @override
 78:   void dispose() {
 79:     _searchController.dispose();
 80:     _scrollController.dispose();
 81:     super.dispose();
 82:   }
 83: 
 84:   void _applyFilter(String query) {
 85:     final q = query.trim().toLowerCase();
 86:     final result = q.isEmpty
 87:         ? List<CategoryModel>.of(_all)
 88:         : _all.where((c) => c.name.toLowerCase().contains(q)).toList();
 89: 
 90:     _sectionKeys.clear();
 91:     final lettersSet = <String>{};
 92:     for (final c in result) {
 93:       if (c.name.isEmpty) continue;
 94:       lettersSet.add(c.name[0].toUpperCase());
 95:     }
 96:     final letters = lettersSet.toList()..sort();
 97:     for (final l in letters) {
 98:       _sectionKeys[l] = GlobalKey();
 99:     }
100: 
101:     setState(() {
102:       _filtered = result;
103:       _letters = letters;
104:       _activeLetter = null;
105:     });
106:   }
107: 
108:   void _scrollToLetter(String letter) {
109:     final ctx = _sectionKeys[letter]?.currentContext;
110:     if (ctx == null) return;
111:     HapticFeedback.selectionClick();
112:     setState(() => _activeLetter = letter);
113:     Scrollable.ensureVisible(
114:       ctx,
115:       duration: const Duration(milliseconds: 300),
116:       curve: Curves.easeOut,
117:       alignment: 0.0,
118:     );
119:   }
120: 
121:   @override
122:   Widget build(BuildContext context) {
123:     final colorScheme = Theme.of(context).colorScheme;
124: 
125:     return Scaffold(
126:       appBar: AppBar(
127:         title: const Text('Categorias de serviços'),
128:         bottom: PreferredSize(
129:           preferredSize: const Size.fromHeight(56),
130:           child: Padding(
131:             padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
132:             child: TextField(
133:               controller: _searchController,
134:               onChanged: _applyFilter,
135:               decoration: InputDecoration(
136:                 hintText: 'Buscar categoria…',
137:                 prefixIcon: const Icon(Icons.search),
138:                 suffixIcon: _searchController.text.isNotEmpty
139:                     ? IconButton(
140:                         icon: const Icon(Icons.clear),
141:                         onPressed: () {
142:                           _searchController.clear();
143:                           _applyFilter('');
144:                         },
145:                       )
146:                     : null,
147:                 isDense: true,
148:                 filled: true,
149:                 fillColor: colorScheme.surface,
150:                 border: OutlineInputBorder(
151:                   borderRadius: BorderRadius.circular(12),
152:                   borderSide: BorderSide.none,
153:                 ),
154:               ),
155:             ),
156:           ),
157:         ),
158:       ),
159:       body: FutureBuilder<List<CategoryModel>>(
160:         future: _future,
161:         builder: (context, snapshot) {
162:           if (snapshot.connectionState == ConnectionState.waiting) {
163:             return const Center(child: CircularProgressIndicator());
164:           }
165:           if (snapshot.hasError) {
166:             return Center(
167:               child: Padding(
168:                 padding: const EdgeInsets.all(20),
169:                 child: Text(
170:                   'Erro ao carregar categorias:\\n\${snapshot.error}',
171:                   textAlign: TextAlign.center,
172:                 ),
173:               ),
174:             );
175:           }
176:           if (_filtered.isEmpty) {
177:             return const Center(
178:               child: Text('Nenhuma categoria encontrada.'),
179:             );
180:           }
181: 
182:           // agrupa por letra
183:           final Map<String, List<CategoryModel>> grouped = {};
184:           for (final c in _filtered) {
185:             if (c.name.isEmpty) continue;
186:             grouped.putIfAbsent(c.name[0].toUpperCase(), () => []).add(c);
187:           }
188: 
189:           return Stack(
190:             children: [
191:               ListView.builder(
192:                 controller: _scrollController,
193:                 padding: const EdgeInsets.only(right: 32),
194:                 itemCount: _letters.length,
195:                 itemBuilder: (_, i) {
196:                   final letter = _letters[i];
197:                   final items = grouped[letter] ?? [];
198:                   return Column(
199:                     crossAxisAlignment: CrossAxisAlignment.start,
200:                     children: [
201:                       Container(
202:                         key: _sectionKeys[letter],
203:                         width: double.infinity,
204:                         color: colorScheme.surfaceContainerHighest,
205:                         padding: const EdgeInsets.symmetric(
206:                           horizontal: 16,
207:                           vertical: 6,
208:                         ),
209:                         child: Text(
210:                           letter,
211:                           style: TextStyle(
212:                             fontWeight: FontWeight.bold,
213:                             fontSize: 13,
214:                             color: colorScheme.onSurfaceVariant,
215:                           ),
216:                         ),
217:                       ),
218:                       ...items.map(
219:                         (category) => ListTile(
220:                           title: Text(category.name),
221:                           trailing: const Icon(Icons.arrow_forward_ios, size: 16),
222:                           onTap: () => Navigator.push(
223:                             context,
224:                             MaterialPageRoute(
225:                               builder: (_) => ProvidersPage(
226:                                 categoryId: category.id,
227:                                 categoryName: category.name,
228:                               ),
229:                             ),
230:                           ),
231:                         ),
232:                       ),
233:                     ],
234:                   );
235:                 },
236:               ),
237:               if (_searchController.text.isEmpty)
238:                 Positioned(
239:                   right: 0,
240:                   top: 0,
241:                   bottom: 0,
242:                   child: _AlphabetIndex(
243:                     letters: _letters,
244:                     activeLetter: _activeLetter,
245:                     onLetterTap: _scrollToLetter,
246:                     colorScheme: colorScheme,
247:                   ),
248:                 ),
249:             ],
250:           );
251:         },
252:       ),
253:     );
254:   }
255: }
256: 
257: class _AlphabetIndex extends StatelessWidget {
258:   final List<String> letters;
259:   final String? activeLetter;
260:   final ValueChanged<String> onLetterTap;
261:   final ColorScheme colorScheme;
262: 
263:   const _AlphabetIndex({
264:     required this.letters,
265:     required this.activeLetter,
266:     required this.onLetterTap,
267:     required this.colorScheme,
268:   });
269: 
270:   @override
271:   Widget build(BuildContext context) {
272:     return GestureDetector(
273:       onVerticalDragUpdate: (details) {
274:         final box = context.findRenderObject() as RenderBox?;
275:         if (box == null) return;
276:         final localY = box.globalToLocal(details.globalPosition).dy;
277:         final itemHeight = box.size.height / letters.length;
278:         final idx = (localY / itemHeight).floor().clamp(0, letters.length - 1);
279:         onLetterTap(letters[idx]);
280:       },
281:       child: Container(
282:         width: 28,
283:         decoration: BoxDecoration(
284:           color: colorScheme.surfaceContainerHighest.withValues(alpha: 0.9),
285:           borderRadius: const BorderRadius.only(
286:             topLeft: Radius.circular(8),
287:             bottomLeft: Radius.circular(8),
288:           ),
289:         ),
290:         child: Column(
291:           mainAxisAlignment: MainAxisAlignment.center,
292:           children: letters.map((l) {
293:             final isActive = l == activeLetter;
294:             return GestureDetector(
295:               onTap: () => onLetterTap(l),
296:               child: Container(
297:                 width: 28,
298:                 height: 22,
299:                 alignment: Alignment.center,
300:                 decoration: isActive
301:                     ? BoxDecoration(
302:                         color: colorScheme.primary,
303:                         shape: BoxShape.circle,
304:                       )
305:                     : null,
306:                 child: Text(
307:                   l,
308:                   style: TextStyle(
309:                     fontSize: 11,
310:                     fontWeight: FontWeight.bold,
311:                     color: isActive
312:                         ? colorScheme.onPrimary
313:                         : colorScheme.onSurfaceVariant,
314:                   ),
315:                 ),
316:               ),
317:             );
318:           }).toList(),
319:         ),
320:       ),
321:     );
322:   }
323: }
324: """
325: 
