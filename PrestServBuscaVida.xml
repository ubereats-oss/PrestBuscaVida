<file path="add_export_compliance.py">
 1: import os
 2: import xml.etree.ElementTree as ET
 3: 
 4: PLIST_PATH = os.path.join("ios", "Runner", "Info.plist")
 5: 
 6: def main():
 7:     if not os.path.exists(PLIST_PATH):
 8:         print("❌ Info.plist não encontrado em ios/Runner/")
 9:         return
10: 
11:     tree = ET.parse(PLIST_PATH)
12:     root = tree.getroot()
13: 
14:     dict_elem = root.find("dict")
15:     if dict_elem is None:
16:         print("❌ Estrutura inválida no Info.plist")
17:         return
18: 
19:     # Verificar se já existe
20:     keys = list(dict_elem)
21:     for i in range(0, len(keys), 2):
22:         if keys[i].tag == "key" and keys[i].text == "ITSAppUsesNonExemptEncryption":
23:             print("⚠️ Já existe. Nenhuma alteração feita.")
24:             return
25: 
26:     # Inserir no final
27:     key = ET.Element("key")
28:     key.text = "ITSAppUsesNonExemptEncryption"
29: 
30:     value = ET.Element("false")
31: 
32:     dict_elem.append(key)
33:     dict_elem.append(value)
34: 
35:     tree.write(PLIST_PATH, encoding="utf-8", xml_declaration=True)
36: 
37:     print("✅ Inserido com sucesso no Info.plist")
38: 
39: if __name__ == "__main__":
40:     main()
</file>

