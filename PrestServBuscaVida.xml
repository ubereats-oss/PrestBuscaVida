 3:   if (digits.length == 11) {
 4:     return '(${digits.substring(0, 2)}) ${digits.substring(2, 7)}-${digits.substring(7)}';
 5:   }
 6:   if (digits.length == 10) {
 7:     return '(${digits.substring(0, 2)}) ${digits.substring(2, 6)}-${digits.substring(6)}';
 8:   }
 9:   return raw;
10: }
11: 
12: String formatPhoneInput(String raw) {
13:   final digits = raw.replaceAll(RegExp(r'\D'), '');
14:   if (digits.isEmpty) return '';
15:   if (digits.length <= 2) return '(${digits}';
16:   if (digits.length <= 6) return '(${digits.substring(0, 2)}) ${digits.substring(2)}';
17:   final isCell = digits.length > 10 || (digits.length > 6 && digits[2] == '9');
18:   if (isCell) {
19:     if (digits.length <= 11) {
20:       return '(${digits.substring(0, 2)}) ${digits.substring(2, digits.length > 7 ? 7 : digits.length)}${digits.length > 7 ? '-${digits.substring(7)}' : ''}';
21:     }
22:     return '(${digits.substring(0, 2)}) ${digits.substring(2, 7)}-${digits.substring(7, 11)}';
23:   } else {
24:     if (digits.length <= 10) {
25:       return '(${digits.substring(0, 2)}) ${digits.substring(2, digits.length > 6 ? 6 : digits.length)}${digits.length > 6 ? '-${digits.substring(6)}' : ''}';
26:     }
27:     return '(${digits.substring(0, 2)}) ${digits.substring(2, 6)}-${digits.substring(6, 10)}';
