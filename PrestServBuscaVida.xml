 85:   @override
 86:   State<_PendingTab> createState() => _PendingTabState();
 87: }
 88: class _PendingTabState extends State<_PendingTab> {
 89:   Future<void> _approve(ProviderModel provider) async {
 90:     await widget.providersRepository.approveProvider(provider.id);
 91:     if (mounted) {
 92:       ScaffoldMessenger.of(context).showSnackBar(
 93:         SnackBar(content: Text('${provider.name} aprovado com sucesso.')),
 94:       );
 95:     }
 96:   }
 97:   Future<void> _reject(ProviderModel provider) async {
 98:     final confirmed = await showDialog<bool>(
 99:       context: context,
100:       builder: (ctx) => AlertDialog(
101:         title: const Text('Rejeitar sugestão'),
102:         content: Text('Deseja rejeitar "${provider.name}"?'),
103:         actions: [
104:           TextButton(
105:             onPressed: () => Navigator.pop(ctx, false),
106:             child: const Text('Cancelar'),
107:           ),
108:           FilledButton(
109:             style: FilledButton.styleFrom(
110:               backgroundColor: Theme.of(context).colorScheme.error,
111:             ),
112:             onPressed: () => Navigator.pop(ctx, true),
113:             child: const Text('Rejeitar'),
114:           ),
115:         ],
116:       ),
117:     );
118:     if (confirmed == true) {
119:       await widget.providersRepository.rejectProvider(provider.id);
120:       if (mounted) {
121:         ScaffoldMessenger.of(context).showSnackBar(
122:           SnackBar(content: Text('${provider.name} rejeitado.')),
123:         );
124:       }
125:     }
126:   }
127:   @override
128:   Widget build(BuildContext context) {
129:     return StreamBuilder<List<ProviderModel>>(
130:       stream: widget.providersRepository.watchPendingProviders(),
131:       builder: (context, snapshot) {
132:         if (snapshot.connectionState == ConnectionState.waiting) {
133:           return const Center(child: CircularProgressIndicator());
134:         }
135:         if (snapshot.hasError) {
136:           return Center(child: Text('Erro: ${snapshot.error}'));
137:         }
138:         final pending = snapshot.data ?? [];
139:         if (pending.isEmpty) {
140:           return const Center(
141:             child: Padding(
142:               padding: EdgeInsets.all(20),
143:               child: Text(
144:                 'Nenhuma sugestão pendente.',
145:                 textAlign: TextAlign.center,
146:               ),
147:             ),
148:           );
149:         }
150:         return ListView.separated(
151:           itemCount: pending.length,
152:           separatorBuilder: (_, _) => const Divider(height: 1),
153:           itemBuilder: (context, index) {
154:             final provider = pending[index];
155:             return ListTile(
156:               title: Text(provider.name),
157:               subtitle: Text(
158:                 '${provider.categoryName.isNotEmpty ? provider.categoryName : provider.categoryId}'
159:                 '${provider.description.isNotEmpty ? '\n${provider.description}' : ''}',
160:               ),
161:               isThreeLine: provider.description.isNotEmpty,
162:               trailing: Row(
163:                 mainAxisSize: MainAxisSize.min,
164:                 children: [
165:                   IconButton(
166:                     icon: const Icon(Icons.check_circle_outline),
167:                     color: Colors.green,
168:                     tooltip: 'Aprovar',
169:                     onPressed: () => _approve(provider),
170:                   ),
171:                   IconButton(
172:                     icon: const Icon(Icons.cancel_outlined),
173:                     color: Colors.red,
174:                     tooltip: 'Rejeitar',
175:                     onPressed: () => _reject(provider),
176:                   ),
177:                 ],
178:               ),
179:             );
180:           },
181:         );
182:       },
183:     );
184:   }
185: }
