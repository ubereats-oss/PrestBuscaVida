1423:   38:             ((currentAvg * currentCount) + review.rating) / newCount;
1424:   39:         transaction.update(providerRef, {
1425:   40:           'ratingCount': newCount,
1426:   41:           'avgRating': double.parse(newAvg.toStringAsFixed(1)),
1427:   42:         });
1428:   43:       }
1429:   44:     });
1430:   45:   }
