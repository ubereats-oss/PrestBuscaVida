1417:   32:       if (providerSnap.exists) {
1418:   33:         final data = providerSnap.data()!;
1419:   34:         final currentCount = (data['ratingCount'] ?? 0) as int;
1420:   35:         final currentAvg = _toDouble(data['avgRating']);
1421:   36:         final newCount = currentCount + 1;
