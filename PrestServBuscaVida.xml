<file path="lib/features/providers/providers_page.dart">
  1: import 'package:flutter/material.dart';
  2: import '../../data/models/provider_model.dart';
  3: import '../../data/repositories/providers_repository.dart';
  4: import '../provider_detail/provider_detail_page.dart';
  5: class ProvidersPage extends StatefulWidget {
  6:   final String categoryName;
  7:   final String? categoryId;
  8:   final String? searchQuery;
  9:   const ProvidersPage({
 10:     super.key,
 11:     required this.categoryName,
 12:     this.categoryId,
 13:     this.searchQuery,
 14:   });
 15:   @override
 16:   State<ProvidersPage> createState() => _ProvidersPageState();
 17: }
 18: class _ProvidersPageState extends State<ProvidersPage> {
 19:   final _repository = ProvidersRepository();
 20:   late final Stream<List<ProviderModel>> _stream;
 21:   @override
 22:   void initState() {
 23:     super.initState();
 24:     _stream = _buildStream();
 25:   }
 26:   Stream<List<ProviderModel>> _buildStream() {
 27:     final normalizedSearch = widget.searchQuery?.trim() ?? '';
 28:     if (normalizedSearch.isNotEmpty) {
 29:       return _repository.watchProvidersForSearch(
 30:         searchQuery: normalizedSearch,
 31:       );
 32:     }
 33:     final normalizedCategoryId = widget.categoryId?.trim() ?? '';
 34:     if (normalizedCategoryId.isNotEmpty) {
 35:       return _repository.watchProvidersByCategory(
 36:         categoryId: normalizedCategoryId,
 37:       );
 38:     }
 39:     return _repository.watchProvidersForSearch(searchQuery: '');
 40:   }
 41:   @override
 42:   Widget build(BuildContext context) {
 43:     return Scaffold(
 44:       appBar: AppBar(
 45:         title: Text(widget.categoryName),
 46:       ),
 47:       body: StreamBuilder<List<ProviderModel>>(
 48:         stream: _stream,
 49:         builder: (context, snapshot) {
 50:           if (snapshot.connectionState == ConnectionState.waiting) {
 51:             return const Center(
 52:               child: CircularProgressIndicator(),
 53:             );
 54:           }
 55:           if (snapshot.hasError) {
 56:             return Center(
 57:               child: Padding(
 58:                 padding: const EdgeInsets.all(20),
 59:                 child: Text(
 60:                   'Erro ao carregar prestadores:\n${snapshot.error}',
 61:                   textAlign: TextAlign.center,
 62:                 ),
 63:               ),
 64:             );
 65:           }
 66:           final providers = snapshot.data ?? [];
 67:           if (providers.isEmpty) {
 68:             return const Center(
 69:               child: Padding(
 70:                 padding: EdgeInsets.all(20),
 71:                 child: Text(
 72:                   'Nenhum prestador encontrado.',
 73:                   textAlign: TextAlign.center,
 74:                 ),
 75:               ),
 76:             );
 77:           }
 78:           return ListView.separated(
 79:             itemCount: providers.length,
 80:             separatorBuilder: (_, _) => const Divider(height: 1),
 81:             itemBuilder: (context, index) {
 82:               final provider = providers[index];
 83:               final hasDescription = provider.description.isNotEmpty;
 84:               final ratingLine =
 85:                   'Nota: ${provider.avgRating.toStringAsFixed(1)} '
 86:                   '(${provider.ratingCount} avaliações)';
 87:               return ListTile(
 88:                 title: Text(provider.name),
 89:                 subtitle: Text(
 90:                   hasDescription
 91:                       ? '${provider.description}\n$ratingLine'
 92:                       : ratingLine,
 93:                 ),
 94:                 isThreeLine: hasDescription,
 95:                 trailing: const Icon(Icons.arrow_forward_ios),
 96:                 onTap: () {
 97:                   Navigator.push(
 98:                     context,
 99:                     MaterialPageRoute(
100:                       builder: (_) => ProviderDetailPage(
101:                         provider: provider,
102:                       ),
103:                     ),
104:                   );
105:                 },
106:               );
107:             },
108:           );
109:         },
110:       ),
111:     );
112:   }
113: }
