<file path="lib/data/repositories/reviews_repository.dart">
 1: import 'package:cloud_firestore/cloud_firestore.dart';
 2: import '../models/review_model.dart';
 3: class ReviewsRepository {
 4:   final FirebaseFirestore _firestore;
 5:   ReviewsRepository({
 6:     FirebaseFirestore? firestore,
 7:   }) : _firestore = firestore ?? FirebaseFirestore.instance;
 8:   Stream<List<ReviewModel>> watchReviewsByProvider(String providerId) {
 9:     return _firestore
10:         .collection('reviews')
11:         .where('providerId', isEqualTo: providerId)
12:         .snapshots()
13:         .map((snapshot) {
14:       final reviews = snapshot.docs.map((doc) {
15:         return ReviewModel.fromMap(doc.data(), id: doc.id);
16:       }).toList();
17:       reviews.sort((a, b) => b.createdAt.compareTo(a.createdAt));
18:       return reviews;
19:     });
20:   }
21:   /// Salva a avaliação e recalcula [avgRating] / [ratingCount] atomicamente
22:   /// via [runTransaction], eliminando a race condition de escrita concorrente.
23:   Future<void> addReview({required ReviewModel review}) async {
24:     final reviewRef = _firestore.collection('reviews').doc();
25:     final providerRef =
26:         _firestore.collection('providers').doc(review.providerId);
27:     await _firestore.runTransaction((transaction) async {
28:       final providerSnap = await transaction.get(providerRef);
29:       // Grava a avaliação
30:       transaction.set(reviewRef, review.toMap());
31:       // Atualiza o prestador somente se o documento existir
32:       if (providerSnap.exists) {
33:         final data = providerSnap.data()!;
34:         final currentCount = (data['ratingCount'] ?? 0) as int;
35:         final currentAvg = _toDouble(data['avgRating']);
36:         final newCount = currentCount + 1;
37:         final newAvg =
38:             ((currentAvg * currentCount) + review.rating) / newCount;
39:         transaction.update(providerRef, {
40:           'ratingCount': newCount,
41:           'avgRating': double.parse(newAvg.toStringAsFixed(1)),
42:         });
43:       }
44:     });
45:   }
46:   static double _toDouble(dynamic value) {
47:     if (value is int) return value.toDouble();
48:     if (value is double) return value;
49:     return double.tryParse(value.toString()) ?? 0;
50:   }
51: }
</file>

