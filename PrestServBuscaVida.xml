 28:     } else {
 29:       Copy-Item -Path $src -Destination $dst -Force
 30:     }
 31:     Write-Host "OK  $relativePath"
 32:   } else {
 33:     Write-Host "SKIP $relativePath (nao existe)"
 34:   }
 35: }
 36: 
 37: # Exclui arquivos sensíveis ou gerados de uma pasta antes de copiar
 38: function Copy-FolderFiltered($relativePath, [string[]]$excludePatterns) {
 39:   $src = Join-Path $projectRoot $relativePath
 40:   if (!(Test-Path $src)) {
 41:     Write-Host "SKIP $relativePath (nao existe)"
 42:     return
 43:   }
 44:   $dst = Join-Path $staging $relativePath
 45:   if (!(Test-Path $dst)) { New-Item -ItemType Directory -Path $dst | Out-Null }
 46: 
 47:   Get-ChildItem -Path $src -Recurse -File | Where-Object {
 48:     $rel = $_.FullName.Substring($src.Length + 1)
 49:     $exclude = $false
 50:     foreach ($pattern in $excludePatterns) {
 51:       if ($rel -like $pattern) { $exclude = $true; break }
 52:     }
 53:     -not $exclude
 54:   } | ForEach-Object {
 55:     $rel = $_.FullName.Substring($src.Length + 1)
 56:     $dstFile = Join-Path $dst $rel
 57:     $dstFileDir = Split-Path $dstFile -Parent
 58:     if (!(Test-Path $dstFileDir)) { New-Item -ItemType Directory -Path $dstFileDir | Out-Null }
 59:     Copy-Item -Path $_.FullName -Destination $dstFile -Force
 60:   }
 61:   Write-Host "OK  $relativePath (filtrado)"
 62: }
 63: 
