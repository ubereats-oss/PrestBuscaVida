<file path="publ.bat">
 1: @echo off
 2: 
 3: REM Lê a linha "version: X.Y.Z+N" do pubspec.yaml
 4: for /f "tokens=2 delims= " %%a in ('findstr "^version:" pubspec.yaml') do set FULLVER=%%a
 5: 
 6: REM Separa versionName (antes do +) e versionCode (depois do +)
 7: for /f "tokens=1,2 delims=+" %%a in ("%FULLVER%") do (
 8:     set NAME=%%a
 9:     set CODE=%%b
10: )
11: 
12: REM Separa os três números do versionName
13: for /f "tokens=1,2,3 delims=." %%a in ("%NAME%") do (
14:     set MAJOR=%%a
15:     set MINOR=%%b
16:     set PATCH=%%c
17: )
18: 
19: REM Incrementa patch e versionCode
20: set /a NEWPATCH=%PATCH%+1
21: set /a NEWCODE=%CODE%+1
22: set NEWNAME=%MAJOR%.%MINOR%.%NEWPATCH%
23: 
24: REM Atualiza pubspec.yaml
25: powershell -Command "(Get-Content pubspec.yaml) -replace [regex]::Escape('%NAME%+%CODE%'), '%NEWNAME%+%NEWCODE%' | Set-Content pubspec.yaml"
26: 
27: echo versionName atualizado: %NAME% -^> %NEWNAME%
28: echo versionCode atualizado: %CODE% -^> %NEWCODE%
29: 
30: flutter build appbundle --release
</file>

