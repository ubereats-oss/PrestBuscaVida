  77:     import 'package:cloud_firestore/cloud_firestore.dart';
  78:     import '../models/review_model.dart';
  79: 
  80:     class ReviewsRepository {
  81:       final FirebaseFirestore _firestore;
  82: 
  83:       ReviewsRepository({
  84:         FirebaseFirestore? firestore,
  85:       }) : _firestore = firestore ?? FirebaseFirestore.instance;
  86: 
  87:       Stream<List<ReviewModel>> watchReviewsByProvider(String providerId) {
  88:         return _firestore
  89:             .collection('reviews')
  90:             .where('providerId', isEqualTo: providerId)
  91:             .snapshots()
  92:             .map((snapshot) {
  93:           final reviews = snapshot.docs.map((doc) {
  94:             return ReviewModel.fromMap(doc.data(), id: doc.id);
  95:           }).toList();
  96:           reviews.sort((a, b) => b.createdAt.compareTo(a.createdAt));
  97:           return reviews;
  98:         });
  99:       }
 100: 
 101:       /// Salva a avaliação e recalcula [avgRating] / [ratingCount] atomicamente
 102:       /// via [runTransaction], eliminando a race condition de escrita concorrente.
 103:       Future<void> addReview({required ReviewModel review}) async {
 104:         final reviewRef = _firestore.collection('reviews').doc();
 105:         final providerRef =
 106:             _firestore.collection('providers').doc(review.providerId);
 107: 
 108:         await _firestore.runTransaction((transaction) async {
 109:           final providerSnap = await transaction.get(providerRef);
 110: 
 111:           // Grava a avaliação
 112:           transaction.set(reviewRef, review.toMap());
 113: 
 114:           // Atualiza o prestador somente se o documento existir
 115:           if (providerSnap.exists) {
 116:             final data = providerSnap.data()!;
 117:             final currentCount = (data['ratingCount'] ?? 0) as int;
 118:             final currentAvg = _toDouble(data['avgRating']);
 119:             final newCount = currentCount + 1;
 120:             final newAvg =
 121:                 ((currentAvg * currentCount) + review.rating) / newCount;
 122: 
 123:             transaction.update(providerRef, {
 124:               'ratingCount': newCount,
 125:               'avgRating': double.parse(newAvg.toStringAsFixed(1)),
 126:             });
 127:           }
 128:         });
 129:       }
 130: 
 131:       static double _toDouble(dynamic value) {
 132:         if (value is int) return value.toDouble();
 133:         if (value is double) return value;
 134:         return double.tryParse(value.toString()) ?? 0;
 135:       }
 136:     }
 137: """))
