<file path="exportar_codigo.py">
  1: import os
  2: from datetime import datetime
  3: 
  4: root = os.getcwd()
  5: output = os.path.join(root, "auditoria_codigo_py.txt")
  6: 
  7: # ── Configurações ─────────────────────────────────────────────────────────────
  8: 
  9: EXTENSOES_CODIGO = {'.dart', '.js', '.ts', '.json', '.yaml', '.yml', '.rules', '.md'}
 10: 
 11: EXTENSOES_AUDITORIA = {
 12:     ".dart", ".yaml", ".yml", ".kts", ".gradle",
 13:     ".xml", ".json", ".plist", ".swift"
 14: }
 15: 
 16: IGNORAR_PASTAS = {
 17:     '.git', 'build', '.dart_tool', '.idea',
 18:     '.vscode', 'Pods', '.gradle', 'test',
 19:     'node_modules', '.flutter-plugins'
 20: }
 21: 
 22: IGNORAR_ARQUIVOS = {
 23:     "firebase_options.dart",
 24:     "google-services.json",
 25:     "GoogleService-Info.plist",
 26:     "firebase.json",
 27:     "exportar_codigo.py",
 28:     "auditoria_codigo_py.txt",
 29:     "normalizar_dart.py",
 30:     "package-lock.json",
 31:     "serviceAccountKey.json",
 32: }
 33: 
 34: # ── Arquivos críticos sempre incluídos na auditoria ───────────────────────────
 35: 
 36: def is_critical(full_path):
 37:     n = full_path.replace("\\", "/")
 38:     if n.endswith("MainActivity.kt"):       return True
 39:     if n.endswith(".entitlements"):         return True
 40:     if n.endswith("Info.plist"):            return True
 41:     if n.endswith("AppDelegate.swift"):     return True
 42:     if "network_security_config.xml" in n:  return True
 43:     return False
 44: 
 45: # ── Passo 1: Normalizar quebras de linha ──────────────────────────────────────
 46: 
 47: print("Normalizando arquivos...")
 48: normalizados = 0
 49: 
 50: for dirpath, dirnames, filenames in os.walk(root):
 51:     dirnames[:] = [d for d in dirnames if d not in IGNORAR_PASTAS]
 52: 
 53:     for file in filenames:
 54:         if file in IGNORAR_ARQUIVOS:
 55:             continue
 56:         ext = os.path.splitext(file)[1].lower()
 57:         if ext not in EXTENSOES_CODIGO:
 58:             continue
 59:         caminho = os.path.join(dirpath, file)
 60:         try:
 61:             with open(caminho, 'rb') as f:
 62:                 conteudo = f.read()
 63:             texto = conteudo.decode('utf-8', errors='replace')
 64:             normalizado = texto.replace('\r\r\n', '\n').replace('\r\n', '\n').replace('\r', '\n')
 65:             if not normalizado.endswith('\n'):
 66:                 normalizado += '\n'
 67:             if normalizado != texto:
 68:                 with open(caminho, 'w', encoding='utf-8', newline='\n') as f:
 69:                     f.write(normalizado)
 70:                 normalizados += 1
 71:         except Exception as e:
 72:             print(f'  ERRO ao normalizar {caminho}: {e}')
 73: 
 74: print(f"  {normalizados} arquivo(s) normalizado(s).")
 75: 
 76: # ── Passo 2: Exportar auditoria ───────────────────────────────────────────────
 77: 
 78: print("Gerando auditoria...")
 79: file_count = 0
 80: 
 81: with open(output, "w", encoding="utf-8") as out:
 82:     out.write("==================================================\n")
 83:     out.write(f"AUDITORIA DE CÓDIGO — BioOdonto\n")
 84:     out.write(f"Gerado em: {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}\n")
 85:     out.write(f"Pasta raiz: {root}\n")
 86:     out.write("==================================================\n\n")
 87: 
 88:     for dirpath, dirnames, filenames in os.walk(root):
 89:         dirnames[:] = [d for d in dirnames if d not in IGNORAR_PASTAS]
 90: 
 91:         for file in sorted(filenames):
 92:             if file in IGNORAR_ARQUIVOS:
 93:                 continue
 94:             ext = os.path.splitext(file)[1]
 95:             full_path = os.path.join(dirpath, file)
 96: 
 97:             if not is_critical(full_path):
 98:                 if ext not in EXTENSOES_AUDITORIA:
 99:                     continue
100: 
101:             out.write("==================================================\n")
102:             out.write(f"ARQUIVO: {full_path}\n")
103:             out.write("==================================================\n")
104: 
105:             try:
106:                 with open(full_path, "r", encoding="utf-8") as f:
107:                     for i, line in enumerate(f, start=1):
108:                         out.write(f"{i:4}: {line}")
109:                 file_count += 1
110:             except Exception as e:
111:                 out.write(f"[ERRO ao ler arquivo: {e}]\n")
112: 
113:             out.write("\n\n")
114: 
115:     out.write("==================================================\n")
116:     out.write(f"Total de arquivos exportados: {file_count}\n")
117:     out.write("==================================================\n")
118: 
119: print(f"  Auditoria gerada: {output}")
120: print(f"  Total de arquivos exportados: {file_count}")
</file>

