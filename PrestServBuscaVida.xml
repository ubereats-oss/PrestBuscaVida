 3: from openpyxl import load_workbook
 4: 
 5: CREDENCIAL   = "serviceAccountKey.json"
 6: ARQUIVO_XLSX = "categorias.xlsx"
 7: 
 8: cred = credentials.Certificate(CREDENCIAL)
 9: firebase_admin.initialize_app(cred)
10: db = firestore.client()
11: 
12: wb = load_workbook(ARQUIVO_XLSX, data_only=True)
13: ws = wb["Categorias"]
14: 
15: # Colunas: ID | Nome Atual | Nome Corrigido | Slug | Ordem | Ativo
16: #           0       1             2            3      4       5
17: 
18: atualizados = 0
19: ignorados   = 0
20: erros       = 0
21: 
22: print("Processando planilha...\n")
23: 
24: for row in ws.iter_rows(min_row=2, values_only=True):
25:     doc_id         = str(row[0] or "").strip()
26:     nome_atual     = str(row[1] or "").strip()
27:     nome_corrigido = str(row[2] or "").strip()
28: 
29:     if not doc_id:
30:         continue
31: 
32:     if not nome_corrigido:
33:         print(f"  [IGNORADO] ID {doc_id} — 'Nome Corrigido' está vazio.")
34:         ignorados += 1
35:         continue
36: 
37:     if nome_atual == nome_corrigido:
38:         ignorados += 1
39:         continue
40: 
41:     try:
42:         db.collection("categories").document(doc_id).update({"name": nome_corrigido})
43:         print(f"  [OK] '{nome_atual}'  →  '{nome_corrigido}'")
44:         atualizados += 1
45:     except Exception as e:
46:         print(f"  [ERRO] ID {doc_id}: {e}")
47:         erros += 1
48: 
49: print(f"\nConcluído: {atualizados} atualizadas | {ignorados} sem alteração | {erros} erros.")
</file>

<file path="importar_prestadores.py">
 1: import firebase_admin
 2: from firebase_admin import credentials, firestore
 3: from openpyxl import load_workbook
 4: 
 5: CREDENCIAL   = "serviceAccountKey.json"
 6: ARQUIVO_XLSX = "prestadores_rev1.xlsx"
 7: 
 8: cred = credentials.Certificate(CREDENCIAL)
 9: firebase_admin.initialize_app(cred)
10: db = firestore.client()
11: 
12: wb = load_workbook(ARQUIVO_XLSX, data_only=True)
13: ws = wb["Prestadores"]
14: 
15: # Colunas: ID | Nome Atual | Nome Corrigido | Quem indicou | Observação | Categoria | Status | Telefone | WhatsApp
16: #           0        1             2                3              4           5          6        7          8
17: 
18: atualizados = 0
19: ignorados   = 0
20: erros       = 0
21: 
22: print("Processando planilha...\n")
23: 
24: for row in ws.iter_rows(min_row=2, values_only=True):
25:     doc_id         = str(row[0] or "").strip()
26:     nome_corrigido = str(row[2] or "").strip()
27:     indicacao      = str(row[3] or "").strip()
28:     observacao     = str(row[4] or "").strip()
29:     categoria      = str(row[5] or "").strip()
30: 
31:     if not doc_id:
32:         continue
33: 
34:     if not nome_corrigido:
35:         print(f"  [IGNORADO] ID {doc_id} — 'Nome Corrigido' está vazio.")
36:         ignorados += 1
37:         continue
38: 
39:     try:
40:         db.collection("providers").document(doc_id).update({
41:             "name":        nome_corrigido,
42:             "categoryName": categoria,
43:             "indicacao":   indicacao,
44:             "observacao":  observacao,
45:         })
46:         print(f"  [OK] {nome_corrigido} | cat: {categoria or '—'} | ind: {indicacao or '—'} | obs: {observacao or '—'}")
47:         atualizados += 1
48:     except Exception as e:
49:         print(f"  [ERRO] ID {doc_id}: {e}")
50:         erros += 1
51: 
52: print(f"\nConcluído: {atualizados} atualizados | {ignorados} ignorados | {erros} erros.")
</file>

