<file path="scripts/import_planilha_firestore.js">
  1: const admin = require('firebase-admin');
  2: const xlsx = require('xlsx');
  3: const path = require('path');
  4: const fs = require('fs');
  5: const serviceAccountPath = path.join(__dirname, 'serviceAccountKey.json');
  6: const spreadsheetPath = path.join(__dirname, '..', 'prestadores_importacao.xlsx');
  7: if (!fs.existsSync(serviceAccountPath)) {
  8:   console.error('ERRO: arquivo serviceAccountKey.json nao encontrado na pasta scripts.');
  9:   process.exit(1);
 10: }
 11: if (!fs.existsSync(spreadsheetPath)) {
 12:   console.error('ERRO: planilha nao encontrada na raiz do projeto.');
 13:   console.error('Esperado em:');
 14:   console.error(spreadsheetPath);
 15:   process.exit(1);
 16: }
 17: admin.initializeApp({
 18:   credential: admin.credential.cert(require(serviceAccountPath)),
 19: });
 20: const db = admin.firestore();
 21: function normalizeText(value) {
 22:   return String(value ?? '')
 23:     .normalize('NFD')
 24:     .replace(/[\u0300-\u036f]/g, '')
 25:     .replace(/\s+/g, ' ')
 26:     .trim();
 27: }
 28: function slugify(value) {
 29:   return normalizeText(value)
 30:     .toLowerCase()
 31:     .replace(/[^a-z0-9]+/g, '-')
 32:     .replace(/^-+|-+$/g, '');
 33: }
 34: function digitsOnly(value) {
 35:   return String(value ?? '').replace(/\D/g, '');
 36: }
 37: function toNumber(value) {
 38:   if (value === null || value === undefined || value === '') {
 39:     return 0;
 40:   }
 41:   if (typeof value === 'number') {
 42:     return value;
 43:   }
 44:   const normalized = String(value).replace(',', '.').trim();
 45:   const parsed = Number(normalized);
 46:   return Number.isFinite(parsed) ? parsed : 0;
 47: }
 48: function isSheetTitleRow(row) {
 49:   const colA = normalizeText(row[0]).toLowerCase();
 50:   const colB = normalizeText(row[1]).toLowerCase();
 51:   return (
 52:     colA.includes('lista de prestadores de servico') &&
 53:     colB.includes('nome do prestador')
 54:   );
 55: }
 56: function isCategoryHeaderRow(row) {
 57:   const colA = normalizeText(row[0]);
 58:   const colB = normalizeText(row[1]).toLowerCase();
 59:   const colC = normalizeText(row[2]).toLowerCase();
 60:   if (!colA) {
 61:     return false;
 62:   }
 63:   return colB === 'nome' && colC.includes('contato');
 64: }
 65: function rowHasAnyContent(row) {
 66:   return row.some((cell) => normalizeText(cell) !== '');
 67: }
 68: function buildProviderId(categorySlug, providerName, usedIds) {
 69:   const baseId = slugify(`${categorySlug}-${providerName}`) || `provider-${Date.now()}`;
 70:   let finalId = baseId;
 71:   let counter = 2;
 72:   while (usedIds.has(finalId)) {
 73:     finalId = `${baseId}-${counter}`;
 74:     counter += 1;
 75:   }
 76:   usedIds.add(finalId);
 77:   return finalId;
 78: }
 79: function extractData(sheet) {
 80:   const rows = xlsx.utils.sheet_to_json(sheet, {
 81:     header: 1,
 82:     defval: '',
 83:     raw: false,
 84:   });
 85:   const categories = [];
 86:   const providers = [];
 87:   const usedProviderIds = new Set();
 88:   let currentCategoryName = '';
 89:   let currentCategorySlug = '';
 90:   let currentOrder = 0;
 91:   for (let i = 0; i < rows.length; i += 1) {
 92:     const row = rows[i];
 93:     if (!rowHasAnyContent(row)) {
 94:       continue;
 95:     }
 96:     if (isSheetTitleRow(row)) {
 97:       continue;
 98:     }
 99:     if (isCategoryHeaderRow(row)) {
100:       currentCategoryName = normalizeText(row[0]);
101:       currentCategorySlug = slugify(currentCategoryName);
102:       if (
103:         currentCategorySlug &&
104:         !categories.some((item) => item.slug === currentCategorySlug)
105:       ) {
106:         currentOrder += 1;
107:         categories.push({
108:           id: currentCategorySlug,
109:           name: currentCategoryName,
110:           slug: currentCategorySlug,
111:           order: currentOrder,
112:           isActive: true,
113:         });
114:       }
115:       continue;
116:     }
117:     if (!currentCategorySlug) {
118:       continue;
119:     }
120:     const providerName = normalizeText(row[1]);
121:     const rawContact = row[5] !== '' ? row[5] : row[2];
122:     const phone = digitsOnly(rawContact);
123:     const rating = toNumber(row[3]);
124:     const notes = normalizeText(row[4]);
125:     if (!providerName) {
126:       continue;
127:     }
128:     if (providerName.toLowerCase() === 'nome') {
129:       continue;
130:     }
131:     if (providerName.startsWith('#REF')) {
132:       continue;
133:     }
134:     const providerId = buildProviderId(
135:       currentCategorySlug,
136:       providerName,
137:       usedProviderIds,
138:     );
139:     providers.push({
140:       id: providerId,
141:       name: providerName,
142:       categoryId: currentCategorySlug,
143:       phone,
144:       whatsapp: phone,
145:       description: currentCategoryName,
146:       avgRating: rating,
147:       ratingCount: rating > 0 ? 1 : 0,
148:       notes,
149:       isActive: true,
150:       createdAt: admin.firestore.FieldValue.serverTimestamp(),
151:       updatedAt: admin.firestore.FieldValue.serverTimestamp(),
152:     });
153:   }
154:   return { categories, providers };
155: }
156: async function saveCategories(categories) {
157:   for (const category of categories) {
158:     await db.collection('categories').doc(category.id).set({
159:       name: category.name,
160:       slug: category.slug,
161:       order: category.order,
162:       isActive: category.isActive,
163:     });
164:     console.log(`Categoria salva: ${category.name}`);
165:   }
166: }
167: async function saveProviders(providers) {
168:   for (const provider of providers) {
169:     await db.collection('providers').doc(provider.id).set({
170:       name: provider.name,
171:       categoryId: provider.categoryId,
172:       phone: provider.phone,
173:       whatsapp: provider.whatsapp,
174:       description: provider.description,
175:       avgRating: provider.avgRating,
176:       ratingCount: provider.ratingCount,
177:       notes: provider.notes,
178:       isActive: provider.isActive,
179:       createdAt: provider.createdAt,
180:       updatedAt: provider.updatedAt,
181:     });
182:     console.log(`Prestador salvo: ${provider.name}`);
183:   }
184: }
185: async function main() {
186:   console.log('Abrindo planilha...');
187:   const workbook = xlsx.readFile(spreadsheetPath);
188:   const sheetName = workbook.SheetNames[0];
189:   const sheet = workbook.Sheets[sheetName];
190:   const { categories, providers } = extractData(sheet);
191:   console.log(`Categorias encontradas: ${categories.length}`);
192:   console.log(`Prestadores encontrados: ${providers.length}`);
193:   if (categories.length === 0) {
194:     throw new Error('Nenhuma categoria foi identificada na planilha.');
195:   }
196:   if (providers.length === 0) {
197:     throw new Error('Nenhum prestador foi identificado na planilha.');
198:   }
199:   await saveCategories(categories);
200:   await saveProviders(providers);
201:   console.log('Importacao concluida com sucesso.');
202: }
203: main().catch((error) => {
204:   console.error('Erro na importacao:', error);
205:   process.exit(1);
206: });
</file>

