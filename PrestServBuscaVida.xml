<file path="normalizar_dart.py">
 1: import os, sys
 2: 
 3: pasta = sys.argv[1] if len(sys.argv) > 1 else os.path.join(os.getcwd(), 'lib')
 4: 
 5: # Extensões de código a normalizar
 6: EXTENSOES = {'.dart', '.js', '.ts', '.json', '.yaml', '.yml', '.rules', '.md'}
 7: 
 8: # Pastas a ignorar
 9: IGNORAR_PASTAS = {'node_modules', '.git', 'build', '.dart_tool', '.flutter-plugins'}
10: 
11: for raiz, dirs, arquivos in os.walk(pasta):
12:     # Remove pastas ignoradas do percurso
13:     dirs[:] = [d for d in dirs if d not in IGNORAR_PASTAS]
14: 
15:     for nome in arquivos:
16:         ext = os.path.splitext(nome)[1].lower()
17:         if ext not in EXTENSOES:
18:             continue
19:         caminho = os.path.join(raiz, nome)
20:         try:
21:             with open(caminho, 'rb') as f:
22:                 conteudo = f.read()
23:             texto = conteudo.decode('utf-8', errors='replace')
24:             texto = texto.replace('\r\r\n', '\n').replace('\r\n', '\n').replace('\r', '\n')
25:             linhas = [l for l in texto.split('\n') if l.strip() != '']
26:             texto_final = '\n'.join(linhas) + '\n'
27:             with open(caminho, 'w', encoding='utf-8', newline='\n') as f:
28:                 f.write(texto_final)
29:         except Exception as e:
30:             print(f'ERRO {caminho}: {e}')
31: 
32: print('Normalizacao concluida.')
</file>

