1406:   21:   /// Salva a avaliação e recalcula [avgRating] / [ratingCount] atomicamente
1407:   22:   /// via [runTransaction], eliminando a race condition de escrita concorrente.
1408:   23:   Future<void> addReview({required ReviewModel review}) async {
1409:   24:     final reviewRef = _firestore.collection('reviews').doc();
1410:   25:     final providerRef =
1411:   26:         _firestore.collection('providers').doc(review.providerId);
1412:   27:     await _firestore.runTransaction((transaction) async {
1413:   28:       final providerSnap = await transaction.get(providerRef);
1414:   29:       // Grava a avaliação
1415:   30:       transaction.set(reviewRef, review.toMap());
