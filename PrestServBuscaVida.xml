  6: class CategoriesPage extends StatefulWidget {
  7:   const CategoriesPage({super.key});
  8:   @override
  9:   State<CategoriesPage> createState() => _CategoriesPageState();
 10: }
 11: class _CategoriesPageState extends State<CategoriesPage> {
 12:   final _repository = CategoriesRepository();
 13:   final _searchController = TextEditingController();
 14:   final _scrollController = ScrollController();
 15:   late Future<List<CategoryModel>> _future;
 16:   List<CategoryModel> _all = [];
 17:   List<CategoryModel> _filtered = [];
 18:   String? _activeLetter;
 19:   List<String> _letters = [];
 20:   final Map<String, GlobalKey> _sectionKeys = {};
 21:   @override
 22:   void initState() {
 23:     super.initState();
 24:     _future = _repository.fetchActiveCategories();
 25:     _future.then((list) {
 26:       _all = list;
 27:       _applyFilter('');
 28:     });
 29:   }
 30:   @override
 31:   void dispose() {
 32:     _searchController.dispose();
 33:     _scrollController.dispose();
 34:     super.dispose();
 35:   }
 36:   void _applyFilter(String query) {
 37:     final q = query.trim().toLowerCase();
 38:     final result = q.isEmpty
 39:         ? List<CategoryModel>.of(_all)
 40:         : _all.where((c) => c.name.toLowerCase().contains(q)).toList();
 41:     _sectionKeys.clear();
 42:     final lettersSet = <String>{};
 43:     for (final c in result) {
 44:       if (c.name.isEmpty) continue;
 45:       lettersSet.add(c.name[0].toUpperCase());
 46:     }
 47:     final letters = lettersSet.toList()..sort();
 48:     for (final l in letters) {
 49:       _sectionKeys[l] = GlobalKey();
 50:     }
 51:     setState(() {
 52:       _filtered = result;
 53:       _letters = letters;
 54:       _activeLetter = null;
 55:     });
 56:   }
 57:   void _scrollToLetter(String letter) {
 58:     final ctx = _sectionKeys[letter]?.currentContext;
 59:     if (ctx == null) return;
 60:     HapticFeedback.selectionClick();
 61:     setState(() => _activeLetter = letter);
 62:     Scrollable.ensureVisible(
 63:       ctx,
 64:       duration: const Duration(milliseconds: 300),
 65:       curve: Curves.easeOut,
 66:       alignment: 0.0,
 67:     );
 68:   }
 69:   @override
 70:   Widget build(BuildContext context) {
 71:     final colorScheme = Theme.of(context).colorScheme;
 72:     return Scaffold(
 73:       appBar: AppBar(
 74:         title: const Text('Categorias de serviços'),
 75:         bottom: PreferredSize(
 76:           preferredSize: const Size.fromHeight(56),
 77:           child: Padding(
 78:             padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
 79:             child: TextField(
 80:               controller: _searchController,
 81:               onChanged: _applyFilter,
 82:               decoration: InputDecoration(
 83:                 hintText: 'Buscar categoria…',
 84:                 prefixIcon: const Icon(Icons.search),
 85:                 suffixIcon: _searchController.text.isNotEmpty
 86:                     ? IconButton(
 87:                         icon: const Icon(Icons.clear),
 88:                         onPressed: () {
 89:                           _searchController.clear();
 90:                           _applyFilter('');
 91:                         },
 92:                       )
 93:                     : null,
 94:                 isDense: true,
 95:                 filled: true,
 96:                 fillColor: colorScheme.surface,
 97:                 border: OutlineInputBorder(
 98:                   borderRadius: BorderRadius.circular(12),
 99:                   borderSide: BorderSide.none,
100:                 ),
101:               ),
102:             ),
103:           ),
104:         ),
105:       ),
106:       body: FutureBuilder<List<CategoryModel>>(
107:         future: _future,
108:         builder: (context, snapshot) {
109:           if (snapshot.connectionState == ConnectionState.waiting) {
110:             return const Center(child: CircularProgressIndicator());
111:           }
112:           if (snapshot.hasError) {
113:             return Center(
114:               child: Padding(
115:                 padding: const EdgeInsets.all(20),
116:                 child: Text(
117:                   'Erro ao carregar categorias:\n\${snapshot.error}',
118:                   textAlign: TextAlign.center,
119:                 ),
120:               ),
121:             );
122:           }
123:           if (_filtered.isEmpty) {
124:             return const Center(
125:               child: Text('Nenhuma categoria encontrada.'),
126:             );
127:           }
128:           // agrupa por letra
129:           final Map<String, List<CategoryModel>> grouped = {};
130:           for (final c in _filtered) {
131:             if (c.name.isEmpty) continue;
132:             grouped.putIfAbsent(c.name[0].toUpperCase(), () => []).add(c);
133:           }
134:           return Stack(
135:             children: [
136:               ListView.builder(
137:                 controller: _scrollController,
138:                 padding: const EdgeInsets.only(right: 32),
139:                 itemCount: _letters.length,
140:                 itemBuilder: (_, i) {
141:                   final letter = _letters[i];
142:                   final items = grouped[letter] ?? [];
143:                   return Column(
144:                     crossAxisAlignment: CrossAxisAlignment.start,
145:                     children: [
146:                       Container(
147:                         key: _sectionKeys.putIfAbsent(letter, () => GlobalKey()),
148:                         width: double.infinity,
149:                         color: colorScheme.surfaceContainerHighest,
150:                         padding: const EdgeInsets.symmetric(
151:                           horizontal: 16,
152:                           vertical: 6,
153:                         ),
154:                         child: Text(
155:                           letter,
156:                           style: TextStyle(
157:                             fontWeight: FontWeight.bold,
158:                             fontSize: 13,
159:                             color: colorScheme.onSurfaceVariant,
160:                           ),
161:                         ),
162:                       ),
163:                       ...items.map(
164:                         (category) => ListTile(
165:                           title: Text(category.name),
166:                           trailing: const Icon(Icons.arrow_forward_ios, size: 16),
167:                           onTap: () => Navigator.push(
168:                             context,
169:                             MaterialPageRoute(
170:                               builder: (_) => ProvidersPage(
171:                                 categoryId: category.id,
172:                                 categoryName: category.name,
173:                               ),
174:                             ),
175:                           ),
176:                         ),
177:                       ),
178:                     ],
179:                   );
180:                 },
181:               ),
182:               if (_searchController.text.isEmpty)
183:                 Positioned(
184:                   right: 0,
185:                   top: 0,
186:                   bottom: 0,
187:                   child: _AlphabetIndex(
188:                     letters: _letters,
189:                     activeLetter: _activeLetter,
190:                     onLetterTap: _scrollToLetter,
191:                     colorScheme: colorScheme,
192:                   ),
193:                 ),
194:             ],
195:           );
196:         },
197:       ),
198:     );
199:   }
200: }
201: class _AlphabetIndex extends StatelessWidget {
202:   final List<String> letters;
203:   final String? activeLetter;
204:   final ValueChanged<String> onLetterTap;
205:   final ColorScheme colorScheme;
206:   const _AlphabetIndex({
207:     required this.letters,
208:     required this.activeLetter,
209:     required this.onLetterTap,
210:     required this.colorScheme,
211:   });
212:   @override
213:   Widget build(BuildContext context) {
214:     return GestureDetector(
215:       onVerticalDragUpdate: (details) {
216:         final box = context.findRenderObject() as RenderBox?;
217:         if (box == null) return;
218:         final localY = box.globalToLocal(details.globalPosition).dy;
219:         final itemHeight = box.size.height / letters.length;
220:         final idx = (localY / itemHeight).floor().clamp(0, letters.length - 1);
221:         onLetterTap(letters[idx]);
222:       },
223:       child: Container(
224:         width: 28,
225:         decoration: BoxDecoration(
226:           color: colorScheme.surfaceContainerHighest.withValues(alpha: 0.9),
227:           borderRadius: const BorderRadius.only(
228:             topLeft: Radius.circular(8),
229:             bottomLeft: Radius.circular(8),
230:           ),
231:         ),
232:         child: Column(
233:           mainAxisAlignment: MainAxisAlignment.center,
234:           children: letters.map((l) {
235:             final isActive = l == activeLetter;
236:             return GestureDetector(
237:               onTap: () => onLetterTap(l),
238:               child: Container(
239:                 width: 28,
240:                 height: 22,
241:                 alignment: Alignment.center,
242:                 decoration: isActive
243:                     ? BoxDecoration(
244:                         color: colorScheme.primary,
245:                         shape: BoxShape.circle,
246:                       )
247:                     : null,
248:                 child: Text(
249:                   l,
250:                   style: TextStyle(
251:                     fontSize: 11,
252:                     fontWeight: FontWeight.bold,
253:                     color: isActive
254:                         ? colorScheme.onPrimary
255:                         : colorScheme.onSurfaceVariant,
256:                   ),
257:                 ),
258:               ),
259:             );
260:           }).toList(),
261:         ),
262:       ),
263:     );
264:   }
265: }
</file>

